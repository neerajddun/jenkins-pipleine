pipeline {

    agent {
        docker {
            image 'maven:3.9.10-eclipse-temurin-17'
        }
    }

    environment {
        IMAGE_NAME = "${JOB_NAME}:v1.${BUILD_ID}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Test') {
            steps {
                sh 'mvn clean test'
            }
        }

        stage('Package') {
            steps {
                sh 'mvn -B package -DskipTests'
            }
            post {
                success {
                    archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${IMAGE_NAME} .
                docker tag ${IMAGE_NAME} ${JOB_NAME}:latest
                """
            }
        }

        stage('Deploy to Minikube') {
            steps {
                sh """
                kubectl set image deployment/myapp myapp=${IMAGE_NAME} --namespace=default || \
                kubectl create deployment myapp --image=${IMAGE_NAME}

                kubectl expose deployment myapp --type=NodePort --port=8080 --name=myapp-service || true
                """
            }
        }
    }

    post {
        success {
            echo "Build completed successfully ✔"
        }
        failure {
            echo "Build failed ❌"
        }
    }
}