pipeline {

    agent {
        docker {
            image 'maven:3.9.10-eclipse-temurin-17'
            args '''-v /var/run/docker.sock:/var/run/docker.sock \
                    -v /root/.m2:/root/.m2 \
                    -v /root/.kube:/root/.kube \
                    -v /usr/local/bin/kubectl:/usr/local/bin/kubectl \
                    -u root'''
        }
    }

    environment {
        IMAGE_NAME = "${JOB_NAME}:v1.${BUILD_ID}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Test') {
            steps {
                dir('demo') {
                    sh 'mvn clean test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('demo') {
                    sh 'mvn -B package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'demo/target/*.jar',
                                     fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('demo') {
                    sh """
                        docker build -t ${IMAGE_NAME} .
                        docker tag ${IMAGE_NAME} ${JOB_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy to Minikube') {
            steps {
                sh """
                    kubectl version --client
                    kubectl get nodes

                    if kubectl get deployment myapp --namespace=default > /dev/null 2>&1; then
                        kubectl set image deployment/myapp \
                            myapp=${IMAGE_NAME} --namespace=default
                    else
                        kubectl create deployment myapp \
                            --image=${IMAGE_NAME} --namespace=default
                    fi

                    kubectl patch deployment myapp --namespace=default \
                        -p '{"spec":{"template":{"spec":{"containers":[{"name":"myapp","imagePullPolicy":"Never"}]}}}}'

                    kubectl expose deployment myapp \
                        --type=NodePort \
                        --port=8080 \
                        --name=myapp-service \
                        --namespace=default || true

                    kubectl rollout status deployment/myapp \
                        --namespace=default \
                        --timeout=120s

                    kubectl get pods --namespace=default
                    kubectl get svc myapp-service --namespace=default
                """
            }
        }
    }

    post {
        success {
            echo "Build completed successfully ✔"
            echo "Image: ${IMAGE_NAME}"
        }
        failure {
            echo "Build failed ❌"
            sh '''
                kubectl get pods --namespace=default || true
                kubectl get events --namespace=default --sort-by=.lastTimestamp || true
            '''
        }
    }
}