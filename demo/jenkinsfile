pipeline {

    agent any

    tools {
        maven 'Maven 3.9.10'          // ✅
        jdk 'jdk17'                  // ✅
    }

    environment {
        IMAGE_NAME      = "${JOB_NAME}:v1.${BUILD_ID}"
        DOCKER_HUB_USER = 'neeraj91'
        FULL_IMAGE      = "neeraj91/${JOB_NAME}:v1.${BUILD_ID}"
    }

    stages {

        // ─────────────────────────
        // Stage 1: Checkout
        // ─────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code checked out!"
            }
        }

        // ─────────────────────────
        // Stage 2: Build and Test
        // ─────────────────────────
        stage('Build and Test') {
            steps {
                dir('demo') {
                    sh 'mvn clean test'
                }
            }
        }

        // ─────────────────────────
        // Stage 3: Package
        // ─────────────────────────
        stage('Package') {
            steps {
                dir('demo') {
                    sh 'mvn -B package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts \
                    artifacts: 'demo/target/*.jar', // ✅
                    fingerprint: true
                }
            }
        }

        // ─────────────────────────
        // Stage 4: Build Docker Image
        // ─────────────────────────
        stage('Build Docker Image') {
            steps {
                dir('demo') {
                    sh """
                        docker build -t ${IMAGE_NAME} .
                        docker tag ${IMAGE_NAME} \
                        ${JOB_NAME}:latest
                        echo "✅ Docker image built!"
                    """
                }
            }
        }

        // ─────────────────────────
        // Stage 5: Docker Push
        // ─────────────────────────
        stage('Docker Image Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "$DOCKER_PASS" | \
                        docker login \
                        -u "$DOCKER_USER" \
                        --password-stdin

                        docker tag ${IMAGE_NAME} \
                        ${FULL_IMAGE}

                        docker push ${FULL_IMAGE}

                        docker logout
                        echo "✅ Image pushed!"
                    """
                }
            }
        }
        stage('Deploy ') {
            steps {
                 {
                sh 'echo Deploy'
            }
        }

   