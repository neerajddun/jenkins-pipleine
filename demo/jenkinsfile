pipeline {

    agent any

    tools {
        maven 'Maven 3.6.3'
        jdk 'jdk17'
    }
    environment {

        IMAGE_NAME = "${JOB_NAME}:v1.${BUILD_ID}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build and Test') {
            steps {
                dir('demo') {
                    sh 'mvn clean test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('demo') {
                    sh 'mvn -B package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts artifacts: 'demo/target/*.jar',
                                     fingerprint: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('demo') {
                    sh """
                        docker build -t ${IMAGE_NAME} .
                        docker tag ${IMAGE_NAME} ${JOB_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy to Minikube') {
            steps {
                    echo 'Deploy'
            }
        }
    }

    post {
        success {
            echo "Build completed successfully ✔"
            echo "Image: ${IMAGE_NAME}"
        }
        failure {
            echo "Build failed ❌"
        }
    }
}