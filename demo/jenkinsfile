pipeline {

    agent any

    tools {
        maven 'Maven 3.9.9'          // ✅
        jdk 'jdk17'                  // ✅
    }

    environment {
        IMAGE_NAME      = "${JOB_NAME}:v1.${BUILD_ID}"
        DOCKER_HUB_USER = 'neeraj91'
        FULL_IMAGE      = "neeraj91/${JOB_NAME}:v1.${BUILD_ID}"
    }

    stages {

        // ─────────────────────────
        // Stage 1: Checkout
        // ─────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code checked out!"
            }
        }

        // ─────────────────────────
        // Stage 2: Build and Test
        // ─────────────────────────
        stage('Build and Test') {
            steps {
                dir('demo') {
                    sh 'mvn clean test'
                }
            }
        }

        // ─────────────────────────
        // Stage 3: Package
        // ─────────────────────────
        stage('Package') {
            steps {
                dir('demo') {
                    sh 'mvn -B package -DskipTests'
                }
            }
            post {
                success {
                    archiveArtifacts \
                    artifacts: 'demo/target/*.jar', // ✅
                    fingerprint: true
                }
            }
        }

        // ─────────────────────────
        // Stage 4: Build Docker Image
        // ─────────────────────────
        stage('Build Docker Image') {
            steps {
                dir('demo') {
                    sh """
                        docker build -t ${IMAGE_NAME} .
                        docker tag ${IMAGE_NAME} \
                        ${JOB_NAME}:latest
                        echo "✅ Docker image built!"
                    """
                }
            }
        }

        // ─────────────────────────
        // Stage 5: Docker Push
        // ─────────────────────────
        stage('Docker Image Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "$DOCKER_PASS" | \
                        docker login \
                        -u "$DOCKER_USER" \
                        --password-stdin

                        docker tag ${IMAGE_NAME} \
                        ${FULL_IMAGE}

                        docker push ${FULL_IMAGE}

                        docker logout
                        echo "✅ Image pushed!"
                    """
                }
            }
        }

        // ─────────────────────────
        // Stage 6: Update K8s YAML ✅ Fixed!
        // ─────────────────────────
        stage('Update K8s Manifest') {
            steps {
                sh """
                    sed -i \
                    's|image:.*|image: ${FULL_IMAGE}|g' \
                    k8s/deployment.yaml

                    echo "✅ deployment.yaml updated!"
                    cat k8s/deployment.yaml
                """
            }
        }

        // ─────────────────────────
        // Stage 7: Deploy to Minikube ✅
        // ─────────────────────────
        stage('Deploy to Minikube') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG'
                )]) {
                    sh """
                        kubectl apply \
                        -f k8s/deployment.yaml \
                        --validate=false

                        kubectl apply \
                        -f k8s/service.yaml \
                        --validate=false

                        kubectl rollout status \
                        deployment/demo-app \
                        --timeout=120s

                        echo "✅ Deployed!"
                    """
                }
            }
        }

        // ─────────────────────────
        // Stage 8: Verify ✅
        // ─────────────────────────
        stage('Verify Deployment') {
            steps {
                withCredentials([file(
                    credentialsId: 'kubeconfig',
                    variable: 'KUBECONFIG'
                )]) {
                    sh """
                        echo "=== Pods ==="
                        kubectl get pods \
                        -l app=demo-app

                        echo "=== Service ==="
                        kubectl get svc demo-app-svc

                        echo "=== Deployment ==="
                        kubectl get deployment demo-app

                        echo "✅ Verification done!"
                    """
                }
            }
        }
    }

    // ─────────────────────────
    // Post Actions ✅
    // ─────────────────────────
    post {
        success {
            echo "✅ Pipeline SUCCESS!"
            echo "Image: ${FULL_IMAGE}"
            echo "App deployed to Minikube!"
        }
        failure {
            echo "❌ Pipeline FAILED!"
        }
        always {
            sh """
                docker rmi ${IMAGE_NAME} || true
                docker rmi ${FULL_IMAGE} || true
            """
            cleanWs()
        }
    }
}